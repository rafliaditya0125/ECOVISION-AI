# EcoVision AI - Environment Variables Template
# Salin file ini menjadi .env.local dan isi nilainya sesuai konfigurasi lokal Anda.
# Copy this file to .env.local and fill in the values for your local setup.

# ─────────────────────────────────────────────────────────────
# 1. Google Gemini API Key
# ─────────────────────────────────────────────────────────────
# Dapatkan API Key Anda dari Google AI Studio: https://aistudio.google.com/
# Get your API Key from Google AI Studio: https://aistudio.google.com/
#
# GEMINI_API_KEY       → Server-side only. Used by GeminiProvider to authenticate API calls.
# NEXT_PUBLIC_GEMINI_API_KEY → Exposed to the browser. Sent via the x-api-key HTTP header
#                               to the /api/analyze and /api/chat routes on every request.
#                               Can be overridden at runtime via localStorage("gemini_api_key").

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
NEXT_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ─────────────────────────────────────────────────────────────
# 2. AI Provider Selection
# ─────────────────────────────────────────────────────────────
# Controls which AI backend is used for image classification:
#   gemini → Live Gemini 2.5 Flash model (requires a valid API key above)
#   mock   → Offline simulation; always returns "plastic-pet" at 96% confidence
#             Safe for local development and demos without internet access.

NEXT_PUBLIC_AI_PROVIDER=mock

# ─────────────────────────────────────────────────────────────
# 3. MySQL Database Configuration
# ─────────────────────────────────────────────────────────────
# EcoVision AI requires a running MySQL 8+ server.
# Run `npm run db:migrate` after setup to create all required tables.

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ecovision_db
MYSQL_PORT=3306
