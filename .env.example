# EcoVision AI - Template Environment Variables
# Salin file ini menjadi .env.local dan isi nilainya sesuai konfigurasi lokal Anda.

# ─────────────────────────────────────────────────────────────────────────────
# 1. Google Gemini API Key
# ─────────────────────────────────────────────────────────────────────────────
# Dapatkan API Key Anda dari Google AI Studio: https://aistudio.google.com/
#
# GEMINI_API_KEY            → Hanya tersedia di sisi server (Node.js).
#                             Digunakan oleh GeminiProvider sebagai fallback
#                             jika header x-api-key tidak disertakan dalam request.
#
# NEXT_PUBLIC_GEMINI_API_KEY → Dibundel ke browser. Dibaca oleh src/lib/apiKey.ts
#                              dan dikirim ke server melalui header HTTP x-api-key
#                              pada setiap request ke /api/analyze dan /api/chat.
#                              Dapat di-override saat runtime melalui:
#                              localStorage.setItem("gemini_api_key", "KEY_ANDA")

GEMINI_API_KEY=MASUKKAN_API_KEY_ANDA_DI_SINI
NEXT_PUBLIC_GEMINI_API_KEY=MASUKKAN_API_KEY_ANDA_DI_SINI

# ─────────────────────────────────────────────────────────────────────────────
# 2. Pilihan AI Provider
# ─────────────────────────────────────────────────────────────────────────────
# Menentukan backend AI yang digunakan untuk klasifikasi gambar sampah:
#
#   gemini → Model Gemini 2.5 Flash secara live. Membutuhkan API Key valid di atas.
#   mock   → Simulasi offline. Selalu mengembalikan "plastic-pet" dengan confidence 96%.
#             Aman untuk pengembangan lokal dan demo tanpa koneksi internet.

NEXT_PUBLIC_AI_PROVIDER=gemini

# ─────────────────────────────────────────────────────────────────────────────
# 3. Konfigurasi Database MySQL
# ─────────────────────────────────────────────────────────────────────────────
# EcoVision AI membutuhkan server MySQL 8+ yang berjalan.
# Jalankan `npm run db:migrate` setelah setup untuk membuat semua tabel yang diperlukan.
# Variabel ini hanya dibutuhkan jika NEXT_PUBLIC_DB_STORAGE=mysql (lihat bagian 4).

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ecovision_db
MYSQL_PORT=3306

# ─────────────────────────────────────────────────────────────────────────────
# 4. Provider Penyimpanan Data (Storage Mode)
# ─────────────────────────────────────────────────────────────────────────────
# Menentukan di mana data pengguna (riwayat scan, riwayat chat) disimpan:
#
#   mysql        → Backend MySQL penuh. Login/register diperlukan.
#                  Semua data tersimpan di database MySQL (butuh konfigurasi bagian 3).
#
#   localstorage → Mode Tamu (Guest Mode). Tidak perlu login.
#                  Semua data tersimpan di localStorage browser pengguna.
#                  Data TIDAK tersinkronisasi antar perangkat atau browser.
#                  Cocok untuk demo, penggunaan offline, atau lingkungan tanpa MySQL.

NEXT_PUBLIC_DB_STORAGE=mysql
